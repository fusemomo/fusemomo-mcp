{
  "name": "@fusemomo/fusemomo-mcp",
  "version": "1.0.0",
  "description": "MCP server for FuseMomo behavioral intelligence API - enables AI agents to resolve identities, log interactions, and get behavioral knowledge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "fusemomo-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "fusemomo",
    "ai-agents",
    "claude",
    "behavioral-intelligence",
    "identity-resolution",
    "behavioral-graph",
    "api-integration"
  ],
  "author": "Kshitiz-Mhto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fusemomo/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/fusemomo/mcp-server/issues"
  },
  "homepage": "https://github.com/fusemomo/mcp-server#readme",
  "engines": {
    "node": ">=19.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
