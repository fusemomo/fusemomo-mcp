# ──────────────────────────────────────────────────────────────
# Fusemomo MCP — Environment variables
# ──────────────────────────────────────────────────────────────
#
# SECURITY: Never commit your actual API key.
#
# For production / MCP client usage:
#   Add `export FUSEMOMO_API_KEY="sk_live_..."` to your shell
#   profile (~/.zshrc, ~/.bashrc, $PROFILE) instead of filling
#   this file.  The MCP server reads it from process.env.
#
# For local development only:
#   Copy this file to .env and fill in the values below.
#   .env is listed in .gitignore and will not be committed.
# ──────────────────────────────────────────────────────────────

# Required — your FuseMomo API key (sk_live_... or sk_test_...)
FUSEMOMO_API_KEY=

# Optional overrides
FUSEMOMO_API_URL=https://api.fusemomo.com
FUSEMOMO_TIMEOUT=30000       # HTTP timeout in ms (default: 30000)
LOG_LEVEL=info               # debug | info | warn | error
NODE_ENV=development         # development | production
