# Required
FUSEMOMO_API_KEY=sk_live_your_api_key_here
FUSEMOMO_API_URL=https://api.fusemomo.com # localhost:8001/v1

# Optional
FUSEMOMO_TIMEOUT=30000       # HTTP timeout in milliseconds (default: 30000)
LOG_LEVEL=info               # debug | info | warn | error (default: info)
NODE_ENV=development         # development | production (default: production)
